    @ExecSpace("ClientOnly")
    method table GetCurrentReelStrips()
        if self.reelStrips == nil then
            return nil
        end
        local strips = self.reelStrips[self.baseBet]
        if strips == nil then
            strips = self.reelStrips[1]
        end
        return strips
    end


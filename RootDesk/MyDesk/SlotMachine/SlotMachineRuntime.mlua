            self.winHighlight1,
            self.winHighlight2,
            self.winHighlight3,
            self.winHighlight4,
            self.winHighlight5,
        }
        self.winCellVfx = self:BuildWinCellVfxRefs()
        self.winSymbolOverlays = self:BuildWinSymbolOverlayRefs()
        self.activeWinCells = {}
        self.winVfxFrameRuids = self:BuildWinVfxFrameRuids()
        self.winVfxFrameIndex = 1
        self.winVfxTimerId = nil
        self.premiumUnits = self.initialPremiumCoins * self.coinUnitPerCoin
        self.commonUnits = self.initialCommonCoins * self.coinUnitPerCoin
        self.textTemplates = self:BuildTextTemplates()
        self.baseBetOptions = self:BuildBaseBetOptions()
        self.multiplierOptions = self:BuildMultiplierOptions()
        self.slotSymbols = self:BuildSlotSymbols()
        self.reelStrips = self:BuildReelStrips()
        self.reelStripCellData = self:BuildReelStripCellData()
        self.reelVisualIndex = self:BuildInitialReelVisualIndex()
        self.paytableTenths = self:BuildPaytableTenths()
        self.bonusSlotRules = self:BuildBonusSlotRules()
        self.bonusSlotPaytable = self:BuildBonusSlotPaytable()
        self.bonusSlotTestCheatRemaining = 0
        self.paylines = self:BuildPaylines()
        self.spinProfiles = self:BuildSpinProfiles()
        self.screenSprayVfxConfig = self:BuildScreenSprayVfxConfig()
        self.devCheatCommands = self:BuildCheatCommands()
        self.screenSprayVfxTimerId = nil
        self:HideScreenSprayVfx()
        self:HideBonus777Panel()
        self:ApplyResponsiveLayout()
        self:ConnectDevCheatUi()

        self.multiplierHandlers = {}
        self.baseBetOptionHandlers = {}
        self.baseBetHandler = self.baseBetButton:ConnectEvent(ButtonClickEvent, self.OnBaseBetClicked)
        self.spinHandler = self.spinButton:ConnectEvent(ButtonClickEvent, self.OnSpinClicked)

        for index, button in ipairs(self.multiplierButtons) do
            local selectedMultiplier = index
            local eventHandler = button:ConnectEvent(ButtonClickEvent, function()
                self:SelectMultiplier(selectedMultiplier)
            end)
            table.insert(self.multiplierHandlers, { button = button, eventHandler = eventHandler })
        end

        for index, button in ipairs(self.baseBetOptionButtons) do
            local selectedBaseBet = index
            local eventHandler = button:ConnectEvent(ButtonClickEvent, function()
                self:SelectBaseBet(selectedBaseBet)
            end)
            table.insert(self.baseBetOptionHandlers, { button = button, eventHandler = eventHandler })
        end

        self:SetBaseBetListOpen(false)
        self:HideWinResult()
        self:ResetWinHighlights()
        self:RefreshReelStripResources()
        self:RefreshAllReelPositions()
        self:RefreshAll()
        log("[SlotMachineRuntime] Initialized: true 30-cell reel strips, 3 horizontal paylines, premium=9999")
    end

    @ExecSpace("ClientOnly")
    method void ApplyResponsiveLayout()
        if self.topHudTransform == nil or self.slotPanelTransform == nil then
            return
        end

        local screenWidth = _UILogic.ScreenWidth
        local screenHeight = _UILogic.ScreenHeight
        if screenWidth == nil or screenHeight == nil or screenWidth <= 0 or screenHeight <= 0 then
            return
        end

        local hudScale = math.min(1.0, math.max(0.72, (screenWidth - 80.0) / 780.0))
        self.topHudTransform.UIScale = Vector3(hudScale, hudScale, 1.0)
        self.topHudTransform.anchoredPosition = Vector2(0.0, -18.0)

        local topBand = 18.0 + (60.0 * hudScale) + 36.0
        local leftMargin = 42.0
        local bottomMargin = 24.0
        local slotWidth = 893.0
        local slotHeight = 1020.0
        local slotScaleByWidth = (screenWidth - (leftMargin * 2.0)) / slotWidth
        local slotScaleByHeight = (screenHeight - topBand - bottomMargin) / slotHeight
        local slotScale = math.min(1.0, math.min(slotScaleByWidth, slotScaleByHeight))
        slotScale = math.max(0.48, slotScale)

        self.slotPanelTransform.UIScale = Vector3(slotScale, slotScale, 1.0)
        self.slotPanelTransform.anchoredPosition = Vector2(leftMargin, -topBand)

        if self.battleHudTransform ~= nil and self.battleHudTransform.Entity ~= nil then
            local showBattleHud = screenWidth >= 1500
            self.battleHudTransform.Entity.Enable = showBattleHud
            if showBattleHud then
                self.battleHudTransform.UIScale = Vector3(1.0, 1.0, 1.0)
                self.battleHudTransform.anchoredPosition = Vector2(-240.0, -(topBand + 42.0))
            end
        end
    end

    @ExecSpace("ClientOnly")
    method void OnEndPlay()
        self:StopWinVfxFrameLoop()
        self:HideScreenSprayVfx()
        self:HideBonus777Panel()
        self:DisconnectDevCheatUi()
        if self.baseBetHandler ~= nil then
            self.baseBetButton:DisconnectEvent(ButtonClickEvent, self.baseBetHandler)
            self.baseBetHandler = nil
        end
        if self.spinHandler ~= nil then
            self.spinButton:DisconnectEvent(ButtonClickEvent, self.spinHandler)
            self.spinHandler = nil
        end
        if self.multiplierHandlers ~= nil then
            for _, entry in ipairs(self.multiplierHandlers) do
                entry.button:DisconnectEvent(ButtonClickEvent, entry.eventHandler)
            end
            self.multiplierHandlers = nil
        end
        if self.baseBetOptionHandlers ~= nil then
            for _, entry in ipairs(self.baseBetOptionHandlers) do
                entry.button:DisconnectEvent(ButtonClickEvent, entry.eventHandler)
            end
            self.baseBetOptionHandlers = nil
        end
    end

